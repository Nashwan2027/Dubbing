<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="تسجيل صوتي جديد"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/recordingStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="جاهز للتسجيل"
        android:textSize="16sp"
        android:textColor="#B0B0B0"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/recordingTimer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textSize="48sp"
        android:textStyle="bold"
        android:textColor="#FF2D55"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/recordStartBtn"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="●"
            android:textSize="32sp"
            android:backgroundTint="#FF2D55"
            android:textColor="#FFFFFF"
            android:padding="16dp"
            android:layout_marginEnd="16dp"/>

        <Button
            android:id="@+id/recordStopBtn"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="■"
            android:textSize="28sp"
            android:backgroundTint="#555555"
            android:textColor="#FFFFFF"
            android:padding="16dp"
            android:enabled="false"/>

    </LinearLayout>

    <EditText
        android:id="@+id/recordingName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="اسم التسجيل (اختياري)"
        android:textColor="#FFFFFF"
        android:textColorHint="#666666"
        android:background="@android:drawable/editbox_background"
        android:padding="12dp"
        android:layout_marginTop="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/recordingCancelBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="إلغاء"
            android:backgroundTint="#555555"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/recordingSaveBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="حفظ وإضافة"
            android:backgroundTint="#2E5BFF"
            android:enabled="false"/>

    </LinearLayout>

</LinearLayout>
